# Git attributes file for Windows
# Handle line endings automatically for files detected as text
* text=auto

# Explicitly declare text files you want to always be normalized and converted
# to native line endings on checkout.
*.py text
*.md text
*.yaml text
*.yml text
*.txt text
*.json text

# Denote all files that are truly binary and should not be modified.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.exe binary
*.dll binary
*.zip binary
*.tar binary
*.gz binary
*.bz2 binary
*.7z binary
*.mp3 binary
*.mp4 binary
*.avi binary
*.mov binary
*.wav binary
*.flac binary
*.ogg binary
*.zip binary
*.rar binary